[Unit]
Description=Google Auth Helper FastAPI Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/google-auth-helper
EnvironmentFile=/opt/google-auth-helper/.env
ExecStart=/opt/google-auth-helper/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
