APP_HOST=0.0.0.0
APP_PORT=8000
WORKSPACE_DIR=./workspace
LOGS_DIR=./workspace/logs
FIRMWARE_DIR=./workspace/firmware
DEFAULT_REMOTE_FIRMWARE_PATH=/data/local/tmp
ALLOWED_ORIGINS=*

# 도구 경로(없으면 기본 경로 탐색)
CTS_TOOL_PATH=
GTS_TOOL_PATH=
TVTS_TOOL_PATH=
VTS_TOOL_PATH=
STS_TOOL_PATH=
CTS_ON_GSI_TOOL_PATH=

# 연동 설정
JIRA_BASE_URL=
JIRA_TOKEN=
REDMINE_BASE_URL=
REDMINE_TOKEN=
REDMINE_PROJECT_ID=
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
MONITOR_API_TOKEN=
FIREBASE_BACKEND=firestore
FIREBASE_PROJECT_ID=kani-projects
FIREBASE_API_KEY=
FIREBASE_BEARER_TOKEN=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_HOSTING_URL=https://kani-projects.web.app
FIRESTORE_DATABASE_ID=google-auth
FIRESTORE_DEFAULT_COLLECTION=google-auth

# 결과 watcher 설정
RESULT_WATCHER_ENABLED=true
RESULT_WATCHER_INTERVAL_SEC=15
RESULT_WATCHER_SCAN_LIMIT=300

# 도구별 결과/로그 경로(비우면 TOOL_PATH 기준으로 <base>/results, <base>/logs 사용)
CTS_RESULTS_DIR=
CTS_LOGS_DIR=
GTS_RESULTS_DIR=
GTS_LOGS_DIR=
TVTS_RESULTS_DIR=
TVTS_LOGS_DIR=
VTS_RESULTS_DIR=
VTS_LOGS_DIR=
STS_RESULTS_DIR=
STS_LOGS_DIR=
CTS_ON_GSI_RESULTS_DIR=
CTS_ON_GSI_LOGS_DIR=

# GitHub 연동 기준 저장소
GITHUB_CODE_REPO=greenhelix/dev_logs/Flutter/flutter_project/google_auth_helper
GITHUB_RELEASE_REPO=greenhelix/GAH-Release-Repo
